{
  "info": {
    "_postman_id": "d7b1d5a3-7a3b-4f0e-9f28-0e7b1c7a9d3a",
    "name": "smartvoucher API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "register", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"email\": \"demo_user@example.com\",\n  \"password\": \"DemoPass123!\"\n}"
            }
          }
        },
        {
          "name": "Login (JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) { pm.environment.set('access_token', data.access); }",
                  "if (data.refresh) { pm.environment.set('refresh_token', data.refresh); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"password\": \"DemoPass123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) { pm.environment.set('access_token', data.access); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "refresh", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me/",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Vouchers",
      "item": [
        {
