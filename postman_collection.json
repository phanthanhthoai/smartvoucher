            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"\",\n  \"title\": \"Beverage Voucher\",\n  \"discount_type\": \"fixed\",\n  \"discount_value\": 10000,\n  \"release_date\": \"2026-02-24T10:00:00Z\",\n  \"expiry_date\": \"2026-12-31T23:59:59Z\",\n  \"quantity\": 100,\n  \"event_type\": \"welcome\",\n  \"rule\": {\n    \"required_role\": \"customer\",\n    \"birthday_only\": false,\n    \"min_order_amount\": 0,\n    \"min_items\": 1,\n    \"required_product_type\": \"beverage\",\n    \"period_type\": null\n  }\n}"
            }
          }
