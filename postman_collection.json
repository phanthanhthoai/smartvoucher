            ],
            "url": {
              "raw": "{{base_url}}/api/vouchers/stats/revenue-chart/?group_by=day&start_date={{start_date}}&end_date={{end_date}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vouchers", "stats", "revenue-chart", ""],
              "query": [
                { "key": "group_by", "value": "day" },
                { "key": "start_date", "value": "{{start_date}}" },
                { "key": "end_date", "value": "{{end_date}}" }
              ]
            }
          }
        },
        {
          "name": "Apply Voucher",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
