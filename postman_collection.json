            }
          }
        },
        {
          "name": "Process Order Success Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vouchers/events/order-success/",
              "host": ["{{base_url}}"],
              "path": ["api", "vouchers", "events", "order-success", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"{{event_id}}\",\n  \"user_id\": {{user_id}},\n  \"order_id\": {{order_id}},\n  \"status\": \"paid\",\n  \"total_amount\": 85000,\n  \"paid_at\": \"2026-03-03T10:00:00Z\",\n  \"items\": [\n    {\n      \"name\": \"Tra sua\",\n      \"product_type\": \"beverage\",\n      \"quantity\": 2,\n      \"unit_price\": 30000\n    },\n    {\n      \"name\": \"Banh ngot\",\n      \"product_type\": \"food\",\n      \"quantity\": 1,\n      \"unit_price\": 25000\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Stats Overview",
          "request": {
